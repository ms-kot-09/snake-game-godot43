; Engine configuration file.
; Godot 4.3 — Snake Game

config_version=5

[application]

config/name="Snake Game"
config/description="Snake with skins, RGB editor, and smooth graphics"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0.047, 0.047, 0.075, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameData="*res://scripts/GameData.gd"
SkinManager="*res://scripts/SkinManager.gd"
AudioManager="*res://scripts/AudioManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

